{{- $payload := dict -}}
{{- range $slug, $comments := site.Data.comments -}}
  {{- $items := slice -}}
  {{- range sort $comments "date" "desc" -}}
    {{- $items = $items | append (dict
      "id" .id
      "date" .date
      "dateLabel" (dateFormat "2006-01-02" .date)
      "author" .author
      "url" .url
      "replyTo" .reply_to
      "bodyHTML" (.text | markdownify)
    ) -}}
  {{- end -}}
  {{- $payload = merge $payload (dict $slug $items) -}}
{{- end -}}
{{- $payload | jsonify -}}
